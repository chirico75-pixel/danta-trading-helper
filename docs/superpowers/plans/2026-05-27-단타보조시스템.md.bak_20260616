**`</script>` 바로 위에 삽입:**
```javascript
// ── 강일지 패널 ────────────────────────────────────────
let _tradeSide = 'BUY';

function openTradeModal(side) {
  _tradeSide = side;
  $('modal-title').textContent = side === 'BUY' ? '매수 기록' : '매도 기록';
  $('modal-title').style.color = side === 'BUY' ? '#4ade80' : '#f87171';
  ['m-ticker','m-name','m-price','m-amount','m-reason'].forEach(id => $(id).value = '');
  $('trade-modal').style.display = 'flex';
}

function closeTradeModal() {
  $('trade-modal').style.display = 'none';
}

async function submitTrade() {
  const ticker = $('m-ticker').value.trim();
  const name   = $('m-name').value.trim();
  const price  = parseInt($('m-price').value);
  const amount = parseInt($('m-amount').value);
  const reason = $('m-reason').value.trim();
  if (!ticker || !name || !price || !amount) {
    toast('모든 필드를 입력해주세요', '#f59e0b'); return;
  }
  try {
    await api('POST', '/api/trades', { date: today(), ticker, name, side: _tradeSide, price, amount, reason });
    closeTradeModal();
    loadJournal();
    toast('기록 완료', '#4ade80');
  } catch(e) {
    toast('저장 실패: ' + e.message, '#f87171');
  }
}

async function deleteTrade(id) {
  if (!confirm('삭제하시겠습니까?')) return;
  await api('DELETE', `/api/trades/${id}`);
  loadJournal();
}

function renderMiniChart(trades7) {
  // 최근 7일 손익 인라인 SVG 바 차트
  const dates = [...new Set(trades7.map(t=>t.date))].sort().slice(-7);
  const pnls = dates.map(d => trades7.filter(t=>t.date===d).reduce((s,t)=>s+t.pnl,0));
  const maxAbs = Math.max(1, ...pnls.map(Math.abs));
  const w = 30, h = 30, gap = 4;
  const bars = pnls.map((p,i) => {
    const barH = Math.round((Math.abs(p)/maxAbs)*h*0.9) || 2;
    const y = p >= 0 ? h - barH : h;
    const color = p >= 0 ? '#4ade80' : '#f87171';
    return `<rect x="${i*(w+gap)}" y="${y}" width="${w}" height="${barH}" fill="${color}" rx="2"/>`;
  }).join('');
  $('jnl-chart').innerHTML = `<svg width="${dates.length*(w+gap)}" height="${h+4}" style="margin-top:4px">${bars}</svg>`;
}

async function loadJournal() {
  $('jnl-date').textContent = today();
  const all  = await fetch('/api/trades').then(r=>r.json());
  const todayTrades = all.filter(t=>t.date===today());

  // 손익 계산: 매도 건에 대해 당일 같은 종목 최근 매수와 LIFO 매칭
  const buys = {};
  [...todayTrades].filter(t=>t.side==='BUY').forEach(t => {
    if (!buys[t.ticker]) buys[t.ticker] = [];
    buys[t.ticker].push({...t});
  });
  todayTrades.filter(t=>t.side==='SELL').forEach(t => {
    const stack = buys[t.ticker];
    if (stack && stack.length > 0) {
      const buy = stack.pop();
      const pnl = Math.round((t.price - buy.price) / buy.price * t.amount);
      t.pnl = pnl;
    }
  });

  const total = todayTrades.reduce((s,t)=>s+t.pnl,0);
  $('jnl-total').textContent = (total >= 0 ? '+' : '') + total.toLocaleString() + '원';
  $('jnl-total').style.color = total >= 0 ? '#4ade80' : '#f87171';

  $('jnl-list').innerHTML = todayTrades.map(t => {
    const pnlStr = t.side==='SELL'
      ? `<span style="color:${t.pnl>=0?'#4ade80':'#f87171'};font-weight:bold">${t.pnl>=0?'+':''}${t.pnl.toLocaleString()}원</span>`
      : `<span style="color:#64748b">매수중</span>`;
    return `<div class="row">
      <div style="flex:1">
        <span style="color:#e2e8f0">${t.name}</span>
        <span style="color:#64748b;margin-left:4px">${t.side==='BUY'?'매수':'매도'} ${t.amount.toLocaleString()}원</span>
        ${t.reason ? `<div style="color:#475569;font-size:10px">${t.reason}</div>` : ''}
      </div>
      ${pnlStr}
      <button class="btn btn-gray" style="margin-left:4px" onclick="deleteTrade(${t.id})">✕</button>
    </div>`;
  }).join('');

  renderMiniChart(all);
}

loadJournal();
```

