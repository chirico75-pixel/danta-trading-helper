  </div>
</div>

<div id="grid">
  <div class="panel" id="panel-ranking">
    <div class="panel-title t-yellow">🔥 실시간 급등 랭킹</div>
    <!-- Task 9에서 채움 -->
  </div>
  <div class="panel" id="panel-checklist">
    <div class="panel-title t-purple">✅ 상한가 체크리스트</div>
    <!-- Task 10에서 채움 -->
  </div>
  <div class="panel" id="panel-journal">
    <div class="panel-title t-green">📓 강일지</div>
    <!-- Task 11에서 채움 -->
  </div>
  <div class="panel" id="panel-watchlist">
    <div class="panel-title t-red">👁️ 관심종목</div>
    <!-- Task 12에서 채움 -->
  </div>
</div>

<div id="toast-container"></div>

<script>
// ── 유틸 ──────────────────────────────────────────────
const $ = id => document.getElementById(id);
const today = () => new Date().toISOString().slice(0,10);

function toast(msg, color='#334155') {
  const el = document.createElement('div');
  el.className = 'toast';
  el.style.borderColor = color;
  el.textContent = msg;
  $('toast-container').appendChild(el);
  setTimeout(() => el.remove(), 3200);
}

async function api(method, path, body) {
  const opts = { method, headers: {'content-type':'application/json'} };
  if (body) opts.body = JSON.stringify(body);
  const r = await fetch(path, opts);
  if (!r.ok) throw new Error(await r.text());
  return r.json();
}

// ── 시계 ──────────────────────────────────────────────
function updateClock() {
  const now = new Date();
  const hm = now.toTimeString().slice(0,8);
  const h = now.getHours(), m = now.getMinutes();
  const isOpen = (h > 9 || (h===9 && m>=0)) && (h < 15 || (h===15 && m<=30));
  $('market-time').textContent = `${hm}  ${isOpen ? '장중' : '장마감'}`;
}
setInterval(updateClock, 1000);
updateClock();

// ── SSE ───────────────────────────────────────────────
let sseHandlers = {};

function registerSSE(type, fn) { sseHandlers[type] = fn; }

function connectSSE() {
  const badge = $('status-badge');
  const es = new EventSource('/events');
  es.onopen = () => {
    badge.className = 'connected';
    badge.textContent = '● 연결됨';
  };
  es.onmessage = e => {
    const msg = JSON.parse(e.data);
    if (sseHandlers[msg.type]) sseHandlers[msg.type](msg.data);
  };
  es.onerror = () => {
    badge.className = 'reconnecting';
    badge.textContent = '● 재연결 중...';
    es.close();
    setTimeout(connectSSE, 3000);
  };
}
connectSSE();
</script>

</body>
</html>
```

