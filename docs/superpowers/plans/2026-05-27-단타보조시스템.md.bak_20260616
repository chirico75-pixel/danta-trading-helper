**`</script>` 바로 위에 삽입:**
```javascript
// ── 관심종목 패널 ──────────────────────────────────────
let _watchPrices = {};  // ticker → {price, change_rate}

registerSSE('price_update', data => {
  _watchPrices[data.ticker] = data;
  renderWatchlist();
  checkAlerts(data);
});

function checkAlerts(data) {
  const items = _wlItems || [];
  const item = items.find(w=>w.ticker===data.ticker);
  if (!item) return;
  if (item.target_price && data.price >= item.target_price) {
    toast(`🎯 ${item.name} 목표가 도달! (${data.price.toLocaleString()}원)`, '#4ade80');
    if (Notification.permission === 'granted')
      new Notification(`목표가 도달: ${item.name}`, {body: `현재가 ${data.price.toLocaleString()}원`});
  }
  if (item.stop_loss && data.price <= item.stop_loss) {
    toast(`🚨 ${item.name} 손절가 도달! (${data.price.toLocaleString()}원)`, '#f87171');
    if (Notification.permission === 'granted')
      new Notification(`손절가 도달: ${item.name}`, {body: `현재가 ${data.price.toLocaleString()}원`});
  }
}

let _wlItems = [];

function renderWatchlist() {
  $('wl-list').innerHTML = _wlItems.map(item => {
    const live = _watchPrices[item.ticker];
    const priceStr = live ? live.price.toLocaleString() : '-';
    const rateStr  = live ? `${live.change_rate >= 0 ? '+' : ''}${live.change_rate.toFixed(1)}%` : '';
    const rateColor= live ? (live.change_rate >= 0 ? '#f87171' : '#60a5fa') : '#64748b';
    const border   = live && live.change_rate >= 20 ? '#f87171' : (live && live.change_rate >= 10 ? '#f59e0b' : '#334155');
    return `<div class="row" style="border-left:3px solid ${border}">
      <div style="flex:1">
        <span style="color:#e2e8f0">${item.name}</span>
        <span style="color:${rateColor};font-weight:bold;margin-left:6px">${rateStr}</span>
        <span style="color:#64748b;margin-left:4px">${priceStr}원</span>
        <div style="color:#475569;font-size:10px">목표 ${item.target_price?.toLocaleString()||'-'} / 손절 ${item.stop_loss?.toLocaleString()||'-'}</div>
      </div>
      <button class="btn btn-gray" onclick="removeWatch('${item.ticker}')">✕</button>
    </div>`;
  }).join('');
}

async function addWatch() {
  const ticker = $('wl-ticker').value.trim().toUpperCase();
  const name   = $('wl-name').value.trim();
  if (!ticker || !name) { toast('종목코드와 종목명을 입력하세요', '#f59e0b'); return; }
  const target = parseInt($('wl-target').value) || null;
  const stop   = parseInt($('wl-stop').value)   || null;
  if (_wlItems.length >= 20) { toast('최대 20종목까지 등록 가능합니다', '#f59e0b'); return; }
  await api('POST', '/api/watchlist', {ticker, name, target_price: target, stop_loss: stop});
  ['wl-ticker','wl-name','wl-target','wl-stop'].forEach(id => $(id).value = '');
  if (Notification.permission === 'default') Notification.requestPermission();
  loadWatchlist();
  toast(`${name} 등록됨`, '#4ade80');
}

async function removeWatch(ticker) {
  await api('DELETE', `/api/watchlist/${ticker}`);
  loadWatchlist();
}

async function loadWatchlist() {
  _wlItems = await fetch('/api/watchlist').then(r=>r.json());
  renderWatchlist();
}

loadWatchlist();
```

