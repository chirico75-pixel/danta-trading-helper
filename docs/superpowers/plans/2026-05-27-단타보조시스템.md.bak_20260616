**`</script>` 바로 위에 삽입:**
```javascript
// ── 랭킹 패널 ─────────────────────────────────────────
let _rankMarket = 'J';
let _rankData = {J:[], Q:[], ALL:[]};

function setMarket(m) {
  _rankMarket = m;
  ['J','Q','ALL'].forEach(k => {
    $('btn-'+k).className = 'btn ' + (k===m ? 'btn-blue' : 'btn-gray');
  });
  renderRanking();
}

function renderRanking() {
  const list = $('ranking-list');
  if (!list) return;
  const items = _rankData[_rankMarket] || [];
  list.innerHTML = items.map(it => {
    const hot = it.change_rate >= 20;
    const color = hot ? '#f87171' : (it.change_rate >= 10 ? '#f97316' : '#94a3b8');
    return `<div class="row" style="cursor:pointer;border-left:3px solid ${hot?'#f87171':'transparent'}"
      onclick="fillChecklist('${it.ticker}','${it.name}')">
      <span style="color:#e2e8f0;min-width:80px">${it.name}</span>
      <span style="color:${color};font-weight:${hot?'bold':'normal'};min-width:52px;text-align:right">+${it.change_rate.toFixed(1)}%</span>
      <span style="color:#64748b;min-width:40px;text-align:right">${it.volume_ratio}x</span>
    </div>`;
  }).join('');
}

registerSSE('ranking', data => {
  _rankData = data;
  renderRanking();
});

// 초기 로드
fetch('/api/ranking?market=ALL').then(r=>r.json()).then(d => {
  _rankData.ALL = d;
  fetch('/api/ranking?market=J').then(r=>r.json()).then(j => { _rankData.J = j; renderRanking(); });
  fetch('/api/ranking?market=Q').then(r=>r.json()).then(q => { _rankData.Q = q; });
});
```

