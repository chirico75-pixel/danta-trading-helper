            {"stck_shrn_iscd": "005930", "hts_kor_isnm": "삼성전자",
             "data_rank": "1", "stck_prpr": "75000", "prdy_ctrt": "28.50",
             "acml_vol": "10000000", "prdy_vol": "3000000", "stck_mktc": "5000000000000"}
