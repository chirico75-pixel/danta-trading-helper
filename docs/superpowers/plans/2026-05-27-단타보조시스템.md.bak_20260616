  <div style="background:#1e293b;padding:16px;border-radius:8px;width:280px;display:flex;flex-direction:column;gap:8px">
    <div id="modal-title" style="font-weight:bold;color:#e2e8f0"></div>
    <input id="m-ticker" placeholder="종목코드">
