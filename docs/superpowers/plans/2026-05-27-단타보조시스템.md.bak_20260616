  #toast-container{position:fixed;bottom:16px;right:16px;display:flex;flex-direction:column;gap:6px;z-index:999}
  .toast{background:#1e293b;border:1px solid #334155;padding:8px 14px;border-radius:6px;font-size:11px;animation:fadeout 3s forwards}
  @keyframes fadeout{0%{opacity:1}70%{opacity:1}100%{opacity:0}}
</style>
</head>
<body>

<div id="header">
  <h1>⚡ 단타 보조 시스템</h1>
  <div style="display:flex;gap:10px;align-items:center">
    <span id="market-time"></span>
