</div>
<div id="cl-name" style="color:#64748b;font-size:11px"></div>
<div id="cl-items" style="display:flex;flex-direction:column;gap:3px"></div>
<div id="cl-result" style="display:none;padding:8px;border-radius:4px;text-align:center;font-weight:bold;flex-shrink:0"></div>
```

**`</script>` 바로 위에 삽입:**
```javascript
// ── 체크리스트 패널 ────────────────────────────────────
function fillChecklist(ticker, name) {
  $('cl-ticker').value = ticker;
  $('cl-name').textContent = name;
}

async function runChecklist() {
  const ticker = $('cl-ticker').value.trim();
  if (!ticker) return;
  const news_ok  = confirm(`[${ticker}] 당일 강력 호재 뉴스가 있나요?`);
  const naver_ok = confirm(`[${ticker}] 네이버 실시간 검색에 등재돼 있나요?`);
  try {
    const r = await api('POST', '/api/checklist', { ticker, news_ok, naver_ok });
    const d = r.detail;
    const items = [
      { label:'당일 호재 뉴스',    ok: d.news_ok,   score: 30 },
      { label:'거래량 3배 이상',   ok: d.volume_ok, score: 20 },
      { label:'등락률 20% 이상',   ok: d.surge_ok,  score: 20 },
      { label:'네이버 실검 등재',  ok: d.naver_ok,  score: 15 },
      { label:'시총 1,000억 이하', ok: d.cap_ok,    score: 10 },
      { label:'연속 상한가 아님',  ok: d.no_chain,  score:  5 },
    ];
    $('cl-items').innerHTML = items.map(it =>
      `<div class="row">
        <span>${it.ok ? '✅' : '⬜'} ${it.label}</span>
        <span style="color:${it.ok?'#4ade80':'#475569'}">+${it.score}</span>
      </div>`
    ).join('');
    const el = $('cl-result');
    el.style.display = 'block';
    el.style.background = r.score >= 70 ? '#15803d' : (r.score >= 50 ? '#92400e' : '#7f1d1d');
    el.style.color = '#fff';
    el.textContent = `점수: ${r.score}/100  →  ${r.result}`;
    $('cl-name').textContent = ticker;
  } catch(e) {
    toast('체크리스트 분석 실패: ' + e.message, '#f87171');
  }
}
```

